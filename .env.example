# Sierra — environment template
# Copy to .env and fill all values. NEVER commit .env.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

# ── Application ────────────────────────────────────────────────────────────────
SIERRA_ENV=development

# ── Security ───────────────────────────────────────────────────────────────────
SESSION_SECRET=<generate-strong-random-64-hex-chars>
ARGON2_PEPPER=<generate-strong-random-64-hex-chars>
ALLOWED_ORIGINS=https://localhost

# Enable the built-in 'demo' / 'sierra2024' account (showcase / dev only).
# When 0, the first login runs the wizard and the user creates their own credentials.
SIERRA_DEMO_MODE=0

# ── MQTT ───────────────────────────────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=sierra-backend
MQTT_PASS=<generate-strong-random>
SIERRA_HUB_MQTT_USER=sierra-hub
SIERRA_HUB_MQTT_PASS=<generate-strong-random>

# ── Mock mode ──────────────────────────────────────────────────────────────────
MOCK_MODE=true
MOCK_SCENARIO=default
MOCK_TIME_SCALE=1
MOCK_SEED_HISTORY=true

# ── Real hardware (MOCK_MODE=false only) ───────────────────────────────────────
ESPHOME_API_ENCRYPTION_KEY=<generate-for-real-hw>

# ── App settings ───────────────────────────────────────────────────────────────
TIMEZONE=Europe/Rome
LOG_LEVEL=INFO

# ── Network binding (Raspberry Pi / LAN deploy) ────────────────────────────────
# Default is loopback (laptop dev). Installer sets these to 0.0.0.0 on Pi so
# the UI is reachable from phones/tablets on the same network.
HTTP_BIND=127.0.0.1
MQTT_BIND=127.0.0.1
BACKEND_BIND=127.0.0.1
